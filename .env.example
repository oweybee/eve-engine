# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API-Football via RapidAPI — odds ingestion and result grading.
# Sign up at rapidapi.com, subscribe to "API-Football" (free tier: 100 req/day).
# Add as the API_FOOTBALL_KEY GitHub Actions secret.
API_FOOTBALL_KEY=your-rapidapi-key-here

# Season year (the year the season starts). World Cup 2026 = 2026.
FOOTBALL_SEASON=2026

# API-Football league ID for the active competition. FIFA World Cup = 1.
WORLD_CUP_LEAGUE_ID=1

# Daily request budget (free tier = 100).
DAILY_REQUEST_BUDGET=100

# Active polling window in UTC hours. Sleep window (default 00:00–08:00) costs zero requests.
ACTIVE_START_HOUR=8
ACTIVE_END_HOUR=24

# Optional tuning
EV_THRESHOLD=0.02

# Telegram broadcast (postToX.js) — two-tier channel routing.
#   Prime signals  → paid channel (TELEGRAM_PRIME_CHAT_ID)
#   Value/Longshot → free channel (TELEGRAM_FREE_CHAT_ID)
#   In-play        → TELEGRAM_INPLAY_CHAT_ID
# A channel left unset means that tier is recorded but not posted. If
# TELEGRAM_PRIME_CHAT_ID is unset, Prime falls back to the legacy
# TELEGRAM_CHAT_ID so an un-migrated deploy keeps working.
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_PRIME_CHAT_ID=-100xxxxxxxxxx   # paid channel (Prime only)
TELEGRAM_FREE_CHAT_ID=-100xxxxxxxxxx    # free channel (Value + Longshot)
TELEGRAM_INPLAY_CHAT_ID=               # in-play channel (optional)
TELEGRAM_CHAT_ID=                       # legacy/fallback for Prime
# Optional: invite link to the paid channel, shown as an upsell on free posts.
TELEGRAM_PRIME_INVITE_URL=
