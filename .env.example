# ─────────────────────────────────────────────────────────────────────────────
# EVE engine environment. Copy to .env (git-ignored) for local runs; in
# production these are GitHub Actions secrets/variables. Only the REQUIRED block
# is needed to run the core value engine; everything else has code defaults or
# enables an optional feature (Betfair, Telegram, in-play, alerting).
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED — Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (Project → Settings → API). Bypasses RLS; server/CI only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional alias some scripts accept instead of the service-role key.
# SUPABASE_SECRET_KEY=

# ── REQUIRED — API-Football (RapidAPI) — odds ingestion + result grading ─────
# rapidapi.com → subscribe to "API-Football" (free tier: 100 req/day).
API_FOOTBALL_KEY=your-rapidapi-key-here

# ── External data sources (optional) ─────────────────────────────────────────
# The Odds API (the-odds-api.com) — secondary odds source. Without it that
# ingestion path is skipped.
ODDS_API_KEY=
# Betfair Exchange ingestion (betfairIngest.js). All three needed to enable it.
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_MIN_INTERVAL_MIN=

# ── Distribution & alerting (optional) ───────────────────────────────────────
# Telegram signal posting (postToX.js). Bot token + channel/chat IDs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_INPLAY_CHAT_ID=
# Webhook pinged when the integrity/health check trips.
ENGINE_ALERT_WEBHOOK=
# Set DRY_RUN=1 to compute/post nothing externally (safe local runs).
DRY_RUN=

# ── Season / competition ─────────────────────────────────────────────────────
FOOTBALL_SEASON=2026            # year the season starts (World Cup 2026 = 2026)
WORLD_CUP_LEAGUE_ID=1           # API-Football league id (FIFA World Cup = 1)
DAYS_AHEAD=                     # fixture look-ahead window (days)

# ── Polling window & request budget ──────────────────────────────────────────
ACTIVE_START_HOUR=8             # UTC hour to start active polling
ACTIVE_END_HOUR=24              # UTC hour to stop (sleep window costs 0 requests)
DAILY_REQUEST_BUDGET=100        # API-Football daily request budget (free tier=100)
DAILY_QUOTA=                    # legacy alias of DAILY_REQUEST_BUDGET — set ONE
LIVE_WINDOW_MIN=                # minutes around kickoff treated as "live"

# ── Model tuning (optional — all have sensible code defaults) ─────────────────
EV_THRESHOLD=0.005              # min EV to flag a pre-match value signal
SIGNAL_EDGE=                    # alt edge threshold used by some paths
MIN_BOOKMAKERS=2                # min books required to form a consensus
DEVIG_MARGIN=0.02               # relative de-vig safety shave
ODDS_OUTLIER_MULT=3             # drop a price >Nx / <1/N the median (palpable error)
MAX_PLAUSIBLE_EDGE=0.30         # reject consensus edges above this as data errors
INTEGRITY_EDGE_CAP=             # integrity-alarm edge ceiling
ODDS_MAX_AGE_HOURS=24           # ignore odds older than this
SIGNAL_DEDUP_MINUTES=60         # skip re-signal if same price seen within window
COMPUTE_CONCURRENCY=5           # parallelism for the compute pool
USE_UNIFORM_ALPHA=false         # true = uniform alpha instead of directional
ALPHA_HOME=0.034
ALPHA_DRAW=0.057
ALPHA_AWAY=0.037
ALPHA_UNIFORM=0.05
GOALS_MARKET_TRUST=             # weight on market vs model for goals lines
SECONDARY_DATA_TRUST=           # weight on secondary-market data

# ── Secondary markets / stats ────────────────────────────────────────────────
TYPICAL_MATCH_CARDS=            # prior for the cards model
MIN_CARD_SAMPLE=                # min sample before trusting cards data
TEAM_STATS_LAST_N=              # rolling window for team form
TEAM_STATS_REFRESH_HOURS=       # team-stats cache TTL

# ── ELO model ────────────────────────────────────────────────────────────────
ELO_DEFAULT=                    # starting rating for unseen teams
ELO_HOME_ADV=                   # home-advantage rating points
ELO_K=                          # K-factor (update speed)
ELO_REFRESH_HOURS=              # recompute cadence

# ── In-play engine (optional) ────────────────────────────────────────────────
INPLAY_MODEL_ENABLED=           # enable the in-play value model
INPLAY_WINPROB_ENABLED=         # enable the win-probability model
INPLAY_EV_THRESHOLD=            # min EV to flag an in-play signal
INPLAY_MAX_EDGE=                # cap on in-play edges
INPLAY_MIN_ELO_GAMES=           # min games before ELO feeds in-play
INPLAY_WINPROB_MINUTE_CAP=      # stop win-prob signals after this minute
BASELINE_LEAD_MIN=              # pre-match baseline capture lead time

# ── Accumulators & reporting ─────────────────────────────────────────────────
ACCA_TRACK_LEGS=                # legs per tracked accumulator
PERFORMANCE_EPOCH=              # start date for performance summary
# GITHUB_RUN_ID is injected by GitHub Actions — do not set manually.
