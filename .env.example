# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API-Football via RapidAPI — odds ingestion and result grading.
# Sign up at rapidapi.com, subscribe to "API-Football" (free tier: 100 req/day).
# Add as the RAPIDAPI_KEY GitHub Actions secret.
RAPIDAPI_KEY=your-rapidapi-key-here

# Season year (the year the season starts — e.g. 2025 for 2025-26). Optional.
# FOOTBALL_SEASON=2025

# Optional tuning
EV_THRESHOLD=0.02
