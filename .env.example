# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The Odds API (theoddsapi.com)
ODDS_API_KEY=your-odds-api-key-here

# API-Football via RapidAPI — used by fetchResults.js to settle value_signals.
# Sign up free at rapidapi.com, subscribe to "API-Football" (free tier: 100 req/day),
# then put the key here and add it as the RAPIDAPI_KEY GitHub Actions secret.
RAPIDAPI_KEY=your-rapidapi-key-here

# Optional tuning
EV_THRESHOLD=0.02
